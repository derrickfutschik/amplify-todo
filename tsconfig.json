{
  "compilerOptions": {
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
      "@platform/*": ["./packages/platform/*"],
      "@todo-backend/*": ["./packages/todo-backend/*"],
      "derrops-conventions": ["./node_modules/derrops-conventions/src/index.ts"]
    }
  }
}
