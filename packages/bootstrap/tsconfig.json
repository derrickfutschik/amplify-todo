{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "derrops-conventions": ["../../node_modules/derrops-conventions/src/index.ts"]
    }
  },
  "include": ["bin/**/*.ts", "lib/**/*.ts"]
}
