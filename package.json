{
  "name": "amplify-todo",
  "private": true,
  "packageManager": "pnpm@8.15.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev --filter=@amplify-todo/todo-app",
    "build": "turbo build --filter=@amplify-todo/todo-app",
    "preview": "turbo preview --filter=@amplify-todo/todo-app",
    "sandbox:platform": "turbo sandbox --filter=@amplify-todo/platform",
    "sandbox:todo": "turbo sandbox --filter=@amplify-todo/todo-backend",
    "generate-outputs:platform": "turbo generate-outputs --filter=@amplify-todo/platform",
    "generate-outputs:todo": "turbo generate-outputs --filter=@amplify-todo/todo-backend",
    "bootstrap:deploy": "turbo deploy --filter=@amplify-todo/bootstrap",
    "bootstrap:diff": "turbo diff --filter=@amplify-todo/bootstrap"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.17.0",
    "turbo": "^2.3.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "derrops-conventions": "^0.1.4"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.28.1",
      "fast-xml-parser": ">=5.7.0",
      "fast-xml-builder": ">=1.2.0",
      "handlebars": ">=4.7.9",
      "immutable": ">=4.0.0",
      "lodash": ">=4.18.1",
      "uuid": ">=11.1.1"
    }
  }
}
